NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional: Google Maps Platform (address autocomplete on new/edit bid). Restrict key by HTTP referrer in Google Cloud.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: Maps Static API — server-only; satellite preview on new bid confirm + bid detail. Enable "Maps Static API" on this key.
# GOOGLE_MAPS_STATIC_API_KEY=

# Optional: public origin of this app (no trailing slash). Used when generating proposals to fetch the satellite image server-side. On Vercel, VERCEL_URL is used if unset; set this for a stable canonical URL (e.g. custom domain).
# NEXT_PUBLIC_APP_URL=https://your-deployment.example.com

# Optional: OpenStreetMap Overpass API interpreter URL (default: https://overpass-api.de/api/interpreter). Use a self-hosted Overpass for heavy traffic.
# OVERPASS_API_URL=

# Anthropic API key. Powers: onboarding website enrichment (Haiku), the
# dashboard composer intent parsing, and the Ask tab (Opus 4.8). Each degrades
# gracefully without it — onboarding Step 2 shows empty fields, the composer
# falls back to a keyword mock, and Ask returns a grounded offline summary.
# Set this to enable real model calls.
# ANTHROPIC_API_KEY=
